{
  "schema_version": 1,
  "model_id": "default_behavior",
  "model_version": "0.1.0",
  "onnx": "assets/behavior/default_behavior.onnx",
  "onnx_checksum_fnv1a64": "REPLACE_WITH_REAL_FNV1A64",
  "extra_onnx": [],
  "io_contract": {
    "inputs": ["input"],
    "outputs": ["output"]
  },
  "fusion": {
    "mode": "weighted_average",
    "local_weight": 1.0,
    "plugin_weight": 1.0,
    "normalize_by_weight_sum": true
  },
  "postprocess": {
    "steps": [
      { "type": "normalize", "name": "norm_l1", "epsilon": 0.000001 },
      { "type": "argmax", "name": "pick_top1" },
      { "type": "threshold", "name": "blink_gate", "threshold": 0.55 }
    ]
  },
  "routing": {
    "default_route": "unknown",
    "rules": [
      {
        "name": "game",
        "scene_keywords": ["game"],
        "task_keywords": ["game", "match", "lobby", "settlement", "menu"],
        "opacity_bias": 0.08
      },
      {
        "name": "code",
        "scene_keywords": ["code", "ide"],
        "task_keywords": ["work", "coding", "debugging"],
        "opacity_bias": 0.03
      },
      {
        "name": "meeting",
        "scene_keywords": ["meeting"],
        "task_keywords": ["meeting_notes"],
        "opacity_bias": -0.05
      }
    ]
  }
}
